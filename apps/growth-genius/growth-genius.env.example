# Plugin-specific env for growth-genius
# Copy to apps/growth-genius/growth-genius.env and fill in the values you need for this plugin.

DISCORD_BOT_KEY=

GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# External analytics endpoints in apps/growth-genius/data/endpoints/*.json
# reference API key env vars by name through their "apiKeyEnv" field.
ENDPOINT_SECRET=